library IEEE;
use IEEE.std_logic_1164.ALL;
use IEEE.STD_LOGIC_ARITH.all;
use IEEE.STD_LOGIC_UNSIGNED.all;

Entity UserRdDdr Is
	Port
	(
		RstB			: in	std_logic;							
		Clk				: in	std_logic;							

		DipSwitch		: in 	std_logic_vector( 1 downto 0 );
		
		-- HDMICtrl I/F
		HDMIReq			: out	std_logic;
		HDMIBusy		: in	std_logic;
		
		-- RdCtrl I/F
		MemInitDone		: in	std_logic;
		MtDdrRdReq		: out	std_logic;
		MtDdrRdBusy		: in	std_logic;
		MtDdrRdAddr		: out	std_logic_vector( 28 downto 7 );
		
		-- D2URdFf I/F
		D2URdFfWrEn		: in	std_logic;
		D2URdFfWrData	: in	std_logic_vector( 63 downto 0 );
		D2URdFfWrCnt	: out	std_logic_vector( 15 downto 0 );
		
		-- URd2HFf I/F
		URd2HFfWrEn		: out	std_logic;
		URd2HFfWrData	: out	std_logic_vector( 63 downto 0 );
		URd2HFfWrCnt	: in	std_logic_vector( 15 downto 0 )
	);
End Entity UserRdDdr;

Architecture rtl Of UserRdDdr Is

-- Signal declaration
signal	rMemInitDone	: std_logic_vector( 1 downto 0 );
signal	rHDMIReq		: std_logic;
signal rMtDdrRdReq  : std_logic ;
signal rMtDdrRdAddr : std_logic_vector(28 downto 7) ;
signal rRdFlag      : std_logic;

Begin

-- Output assignment
HDMIReq			<= rHDMIReq;
URd2HFfWrEn <= D2URdFfWrEn;
URd2HFfWrData <= D2URdFfWrData;
D2URdFfWrCnt <= URd2HFfWrCnt;
MtDdrRdReq <= rMtDdrRdReq;
MtDdrRdAddr <= rMtDdrRdAddr;

-- Synchronize MemInitDone (2-stage)
u_rMemInitDone : Process (Clk) Is
Begin
	if ( rising_edge(Clk) ) then
		if ( RstB='0' ) then
			rMemInitDone	<= "00";
		else
			rMemInitDone	<= rMemInitDone(0) & MemInitDone;
		end if;
	end if;
End Process u_rMemInitDone;

-- HDMI request control (unchanged)
u_rHDMIReq : Process (Clk) Is
Begin
	if ( rising_edge(Clk) ) then
		if ( RstB='0' ) then
			rHDMIReq	<= '0';
		else
			if ( HDMIBusy='0' and rMemInitDone(1)='1' ) then
				rHDMIReq	<= '1';
			elsif ( HDMIBusy='1' )  then
				rHDMIReq	<= '0';
			else
				rHDMIReq	<= rHDMIReq;
			end if;
		end if;
	end if;
End Process u_rHDMIReq;

-- Read request control: request when DDR free AND HDMI FIFO has room (URd2HFfWrCnt < 32)
u_RdReqCtrl : process (Clk)
begin
	if rising_edge(Clk) then
		if (RstB = '0') then
			rMtDdrRdReq <= '0';
		else
			if (rMemInitDone(1)='1') then
				-- if DDR busy then do not request
				if (MtDdrRdBusy = '1') then
					rMtDdrRdReq <= '0';
				else
					-- Request read when HDMI FIFO has space (less than threshold)
					-- Note: threshold kept small (32) to match original working behavior
					if (to_integer(unsigned(URd2HFfWrCnt)) < 32) then
						rMtDdrRdReq <= '1';
					else
						rMtDdrRdReq <= '0';
					end if;
				end if;
			else
				rMtDdrRdReq <= '0';
			end if;
		end if;
	end if;
end process;

-- Address control: increment lower field until 24575, then increment region bits (28:27)
-- Initialize top bits from DipSwitch at reset so you can select starting bank
u_RdAddressCtrl : process (Clk)
begin
	if (rising_edge(Clk)) then
		if (RstB = '0') then
			-- set starting bank from DipSwitch at reset (you can change policy if desired)
			rMtDdrRdAddr(28 downto 27) <= DipSwitch;
			rMtDdrRdAddr(26 downto 7)  <= (others => '0');
		else
			if (rMemInitDone(1)='1') then
				-- Only update address when read request asserted and DDR acknowledges (busy high) --
				-- This matches write-side behavior where address advanced when req and busy asserted.
				if (rMtDdrRdReq = '1' and MtDdrRdBusy = '1') then
					-- Compare lower field (26 downto 7) to 24575
					if (to_integer(unsigned(rMtDdrRdAddr(26 downto 7))) = 24575) then
						-- if region bits already "11", wrap back to 00 (or you could set to DipSwitch)
						if (rMtDdrRdAddr(28 downto 27) = "11") then
							-- wrap to starting bank specified by DipSwitch (or to "00" if you prefer)
							rMtDdrRdAddr(28 downto 27) <= DipSwitch;
						else
							-- increment region bits
							rMtDdrRdAddr(28 downto 27) <= std_logic_vector(unsigned(rMtDdrRdAddr(28 downto 27)) + 1);
						end if;
						-- reset lower field
						rMtDdrRdAddr(26 downto 7) <= (others => '0');
					else
						-- increment lower field
						rMtDdrRdAddr(26 downto 7) <= std_logic_vector(unsigned(rMtDdrRdAddr(26 downto 7)) + 1);
					end if;
				end if;
			end if;
		end if;
	end if;
end process;

End Architecture rtl;
